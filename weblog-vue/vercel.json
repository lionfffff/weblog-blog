{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://api.myweblog.site/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "http://api.myweblog.site/images/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "http://api.myweblog.site/uploads/$1"
    }
  ]
}
